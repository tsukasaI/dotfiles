# eval cache helper: caches command output, invalidates when binary changes
_cached_eval() {
  local name=$1 cmd=$2
  local cache_dir="$HOME/.cache/zsh"
  local cache="$cache_dir/$name.zsh"
  local bin=$(command -v ${cmd%% *} 2>/dev/null)
  if [[ -n "$bin" && ( ! -f "$cache" || "$bin" -nt "$cache" ) ]]; then
    mkdir -p "$cache_dir"
    eval "$cmd" > "$cache"
  fi
  [[ -f "$cache" ]] && source "$cache"
}

